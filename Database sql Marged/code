-- =========================
-- 3. Catalog (Categories)
-- =========================
CREATE TABLE catalog (
    catalog_id INT PRIMARY KEY AUTO_INCREMENT,
    category_name VARCHAR(50) UNIQUE NOT NULL,
    description TEXT
);

INSERT INTO catalog (category_name, description) VALUES
